<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boredom.boredorm.RoomControl.RoomController" prefWidth="1024" prefHeight="768" style="-fx-background-color: #FFFFFF;">
    <left>
        <VBox fx:id="sidebar" spacing="15" prefWidth="200" style="-fx-background-color: #0A0A0A; -fx-padding: 20;">
            <Label fx:id="sidebarTitle" text="BoreDorm" style="-fx-font-family: 'Georgia'; -fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-padding: 0 0 20 0;"/>
            <Button fx:id="navDashboard" text="Dashboard" onAction="#handleNavDashboard" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navTenants" text="Tenants" onAction="#handleNavTenants" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navRooms" text="Rooms" onAction="#handleNavRooms" style="-fx-background-color: #FFFFFF; -fx-text-fill: #0A0A0A; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-weight: bold; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navBilling" text="Billing" onAction="#handleNavBilling" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navMaintenance" text="Maintenance" onAction="#handleNavMaintenance" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="btnSignOut" text="Sign Out" onAction="#handleSignOut" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <HBox fx:id="splitPane" spacing="20" style="-fx-background-color: #FFFFFF; -fx-padding: 30;">
            <ScrollPane fx:id="leftScrollPane" fitToWidth="true" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background: #FFFFFF; -fx-border-color: transparent;">
                <VBox fx:id="roomsContainer" spacing="24">
                    <VBox spacing="10">
                        <Label fx:id="pageTitle" text="Rooms &amp; Occupancy" style="-fx-font-family: 'Georgia'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 10 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 2 0;"/>
                        <!-- Real-time Summary Cards Layout Container -->
                        <HBox spacing="20" style="-fx-padding: 5 0 10 0;">
                            <VBox style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 1; -fx-padding: 10; -fx-pref-width: 140;">
                                <Label text="Occupied Rooms" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 10; -fx-text-fill: #4A4A4A;"/>
                                <Label fx:id="lblOccupiedCount" text="0" style="-fx-font-family: 'Georgia'; -fx-font-size: 18; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 1; -fx-padding: 10; -fx-pref-width: 140;">
                                <Label text="Vacant Rooms" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 10; -fx-text-fill: #4A4A4A;"/>
                                <Label fx:id="lblVacantCount" text="0" style="-fx-font-family: 'Georgia'; -fx-font-size: 18; -fx-font-weight: bold;"/>
                            </VBox>
                            <VBox style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 1; -fx-padding: 10; -fx-pref-width: 140;">
                                <Label text="Maintenance" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 10; -fx-text-fill: #4A4A4A;"/>
                                <Label fx:id="lblMaintenanceCount" text="0" style="-fx-font-family: 'Georgia'; -fx-font-size: 18; -fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    <VBox fx:id="floor1Container" spacing="12">
                        <Label fx:id="floor1Label" text="First Floor" style="-fx-font-family: 'Georgia'; -fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 4 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 1 0;"/>
                        <FlowPane fx:id="floor1Grid" hgap="12" vgap="12"/>
                    </VBox>
                    <VBox fx:id="floor2Container" spacing="12">
                        <Label fx:id="floor2Label" text="Second Floor" style="-fx-font-family: 'Georgia'; -fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 4 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 1 0;"/>
                        <FlowPane fx:id="floor2Grid" hgap="12" vgap="12"/>
                    </VBox>
                </VBox>
            </ScrollPane>
            <VBox fx:id="rightPanel" spacing="16" prefWidth="320" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 24;" fillWidth="true">
                <Label fx:id="detailsHeader" text="Room Profile" style="-fx-font-family: 'Georgia'; -fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 4 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 1 0;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="detailsRoomTag" text="R101" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-color: #0A0A0A; -fx-text-fill: #FFFFFF; -fx-padding: 4 10; -fx-background-radius: 0;"/>
                    <Label fx:id="detailsStatus" text="Occupied" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 4 8; -fx-border-color: #0A0A0A; -fx-border-width: 1; -fx-background-color: #FFFFFF;"/>
                </HBox>
                <VBox spacing="12">
                    <VBox spacing="4">
                        <Label fx:id="lblRoomType" text="Room Type" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <TextField fx:id="editType" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 8; -fx-text-fill: #0A0A0A; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label fx:id="lblCapacity" text="Capacity" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <TextField fx:id="editCapacity" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 8; -fx-text-fill: #0A0A0A; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label fx:id="lblRate" text="Monthly Rate" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <TextField fx:id="editRate" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 8; -fx-text-fill: #0A0A0A; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label fx:id="lblRoomStatus" text="Status" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <ComboBox fx:id="comboStatus" maxWidth="Infinity" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                    </VBox>
                </VBox>
                <Button fx:id="btnSave" text="Save Configuration" onAction="#handleSaveRoom" maxWidth="Infinity" style="-fx-background-color: #0A0A0A; -fx-text-fill: #FFFFFF; -fx-background-radius: 0; -fx-border-width: 0; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>