<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boredom.boredorm.BillingControl.BillingController" prefWidth="1024" prefHeight="768" style="-fx-background-color: #FFFFFF;">
    <left>
        <VBox fx:id="sidebar" spacing="15" prefWidth="200" style="-fx-background-color: #0A0A0A; -fx-padding: 20;">
            <Label fx:id="sidebarTitle" text="BoreDorm" style="-fx-font-family: 'Georgia'; -fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-padding: 0 0 20 0;"/>
            <Button fx:id="navDashboard" text="Dashboard" onAction="#handleNavDashboard" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navTenants" text="Tenants" onAction="#handleNavTenants" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navRooms" text="Rooms" onAction="#handleNavRooms" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navBilling" text="Billing" onAction="#handleNavBilling" style="-fx-background-color: #FFFFFF; -fx-text-fill: #0A0A0A; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-weight: bold; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navMaintenance" text="Maintenance" onAction="#handleNavMaintenance" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="btnSignOut" text="Sign Out" onAction="#handleSignOut" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <HBox fx:id="splitPane" spacing="20" style="-fx-background-color: #FFFFFF; -fx-padding: 30;">
            <VBox fx:id="leftPanel" spacing="12" prefWidth="500" HBox.hgrow="ALWAYS">
                <Label fx:id="panelTitle" text="Billing &amp; Invoices" style="-fx-font-family: 'Georgia'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 10 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 2 0;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Search tenant or room..." HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 8; -fx-text-fill: #0A0A0A; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                    <ComboBox fx:id="comboFilterStatus" promptText="Status Filter" prefWidth="150" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                </HBox>
                <TableView fx:id="invoiceTable" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-font-family: 'Inter'; -fx-font-size: 12;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTenant" text="Tenant Name" prefWidth="160"/>
                        <TableColumn fx:id="colRoom" text="Room" prefWidth="80"/>
                        <TableColumn fx:id="colPeriod" text="Billing Period" prefWidth="140"/>
                        <TableColumn fx:id="colAmount" text="Amount Due" prefWidth="100"/>
                        <TableColumn fx:id="colStatus" text="Payment Status" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
            <VBox fx:id="rightPanel" spacing="16" prefWidth="300" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 24;" fillWidth="true">
                <Label fx:id="detailsHeader" text="Record Payment" style="-fx-font-family: 'Georgia'; -fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 4 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 1 0;"/>
                <VBox spacing="12">
                    <VBox spacing="4">
                        <Label fx:id="lblAmount" text="Amount Paid" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <TextField fx:id="editAmount" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 8; -fx-text-fill: #0A0A0A; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label fx:id="lblMethod" text="Payment Method" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <ComboBox fx:id="comboMethod" maxWidth="Infinity" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label fx:id="lblDate" text="Payment Date" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <TextField fx:id="editDate" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 8; -fx-text-fill: #0A0A0A; -fx-font-family: 'Inter'; -fx-font-size: 12;"/>
                    </VBox>
                </VBox>
                <Button fx:id="btnRecord" text="Post Transaction" onAction="#handleRecordPayment" maxWidth="Infinity" style="-fx-background-color: #0A0A0A; -fx-text-fill: #FFFFFF; -fx-background-radius: 0; -fx-border-width: 0; -fx-padding: 12 24; -fx-font-family: 'Inter'; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 13;"/>
                <Label fx:id="postStatusLabel" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 6; -fx-border-color: #0A0A0A; -fx-border-width: 1; -fx-background-color: #FFFFFF;" visible="false"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>