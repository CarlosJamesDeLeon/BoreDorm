<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boredom.boredorm.DashboardControl.DashboardController" prefWidth="1024" prefHeight="768" style="-fx-background-color: #FFFFFF;">
    <left>
        <VBox fx:id="sidebar" spacing="15" prefWidth="200" style="-fx-background-color: #0A0A0A; -fx-padding: 20;">
            <Label fx:id="sidebarTitle" text="BoreDorm" style="-fx-font-family: 'Georgia'; -fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-padding: 0 0 20 0;"/>
            <Button fx:id="navDashboard" text="Dashboard" onAction="#handleNavDashboard" maxWidth="Infinity" style="-fx-background-color: #FFFFFF; -fx-text-fill: #0A0A0A; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-weight: bold; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navTenants" text="Tenants" onAction="#handleNavTenants" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navRooms" text="Rooms" onAction="#handleNavRooms" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navBilling" text="Billing" onAction="#handleNavBilling" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Button fx:id="navMaintenance" text="Maintenance" onAction="#handleNavMaintenance" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="btnSignOut" text="Sign Out" onAction="#handleSignOut" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #9C9C9C; -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-font-size: 13; -fx-font-family: 'Inter'; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #FFFFFF; -fx-background: #FFFFFF; -fx-border-color: transparent;">
            <VBox fx:id="contentArea" spacing="24" style="-fx-background-color: #FFFFFF; -fx-padding: 30;">
                <Label fx:id="pageTitle" text="Dashboard Overview" style="-fx-font-family: 'Georgia'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 10 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 2 0;"/>
                <HBox spacing="16" alignment="CENTER">
                    <VBox fx:id="cardOccupied" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-border-radius: 0; -fx-padding: 20; -fx-spacing: 8;">
                        <Label fx:id="lblOccupiedNum" text="42" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0A0A0A;"/>
                        <Label fx:id="lblOccupiedTitle" text="OCCUPIED ROOMS" style="-fx-font-family: 'Inter'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                    </VBox>
                    <VBox fx:id="cardVacant" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-border-radius: 0; -fx-padding: 20; -fx-spacing: 8;">
                        <Label fx:id="lblVacantNum" text="18" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0A0A0A;"/>
                        <Label fx:id="lblVacantTitle" text="VACANT ROOMS" style="-fx-font-family: 'Inter'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                    </VBox>
                    <VBox fx:id="cardPending" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-border-radius: 0; -fx-padding: 20; -fx-spacing: 8;">
                        <Label fx:id="lblPendingNum" text="One thousand" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0A0A0A;"/>
                        <Label fx:id="lblPendingTitle" text="PENDING PAYMENTS" style="-fx-font-family: 'Inter'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                    </VBox>
                    <VBox fx:id="cardRequests" HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-border-radius: 0; -fx-padding: 20; -fx-spacing: 8;">
                        <Label fx:id="lblRequestsNum" text="5" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0A0A0A;"/>
                        <Label fx:id="lblRequestsTitle" text="OPEN MAINTENANCE" style="-fx-font-family: 'Inter'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                    </VBox>
                </HBox>
                <VBox spacing="12">
                    <Label fx:id="gridTitle" text="Room Occupancy Status Grid" style="-fx-font-family: 'Georgia'; -fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 4 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 1 0;"/>
                    <FlowPane fx:id="roomGrid" hgap="12" vgap="12"/>
                </VBox>
                <VBox spacing="12">
                    <Label fx:id="activityTitle" text="Recent Logged Activity" style="-fx-font-family: 'Georgia'; -fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0A0A0A; -fx-padding: 0 0 4 0; -fx-border-color: #0A0A0A; -fx-border-width: 0 0 1 0;"/>
                    <TableView fx:id="activityTable" prefHeight="200" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-font-family: 'Inter'; -fx-font-size: 12;">
                        <columns>
                            <TableColumn fx:id="colTenant" text="Tenant Name" prefWidth="200"/>
                            <TableColumn fx:id="colAction" text="Action Logged" prefWidth="400"/>
                            <TableColumn fx:id="colTimestamp" text="Timestamp" prefWidth="180"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>