<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boredom.boredorm.TenantDashboardControl.TenantDashboardController">
    <!-- Left Sidebar: Sleek Dark Minimalist -->
    <left>
        <VBox prefWidth="220.0" style="-fx-background-color: #121212; -fx-padding: 30 0 30 0;" BorderPane.alignment="CENTER">
            <children>
                <!-- Logo/Brand -->
                <Label text="BoreDorm" textFill="WHITE">
                    <font>
                        <Font name="Georgia Bold" size="22.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="40.0" left="25.0" />
                    </VBox.margin>
                </Label>

                <!-- Navigation Items -->
                <Button maxWidth="Infinity" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: #222222; -fx-text-fill: #FFFFFF; -fx-alignment: center-left; -fx-padding: 0 0 0 25; -fx-background-radius: 0;" text="My Profile">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <!-- Spacer pushing Sign Out to the absolute bottom -->
                <Region VBox.vgrow="ALWAYS" />

                <!-- Sign Out Button (Now fully visible) -->
                <Button fx:id="signOutButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-alignment: center-left; -fx-padding: 0 0 0 25; -fx-cursor: hand;" text="Sign Out">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </left>

    <!-- Main Content Area: Clean Professional Aesthetic -->
    <center>
        <AnchorPane style="-fx-background-color: #FFFFFF;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="50.0" right="50.0" top="50.0" />
            </padding>
            <children>
                <VBox spacing="30.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <!-- Page Title -->
                        <VBox spacing="5.0">
                            <children>
                                <Label text="My Tenant Portal" textFill="#121212">
                                    <font>
                                        <Font name="Georgia Bold" size="28.0" />
                                    </font>
                                </Label>
                                <Label text="Manage your accommodations and profile details" textFill="#666666">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Account Details Card -->
                        <VBox spacing="20.0" style="-fx-border-color: #EAEAEA; -fx-border-width: 1; -fx-background-color: #FAFAFA; -fx-padding: 30; -fx-border-radius: 4; -fx-background-radius: 4;">
                            <children>
                                <GridPane vgap="18.0" hgap="20.0">
                                    <columnConstraints>
                                        <ColumnConstraints prefWidth="150.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="25.0" />
                                        <RowConstraints minHeight="25.0" />
                                        <RowConstraints minHeight="25.0" />
                                    </rowConstraints>
                                    <children>
                                        <!-- Row 1 -->
                                        <Label text="Room Assignment" textFill="#555555" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="roomLabel" text="Loading..." textFill="#121212" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>

                                        <!-- Row 2 -->
                                        <Label text="Username" textFill="#555555" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="usernameLabel" text="Loading..." textFill="#121212" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>

                                        <!-- Row 3 -->
                                        <Label text="Lease Status" textFill="#555555" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="statusLabel" text="Loading..." textFill="#121212" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </center>
</BorderPane>