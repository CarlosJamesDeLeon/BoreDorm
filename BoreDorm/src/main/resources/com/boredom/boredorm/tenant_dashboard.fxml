<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boredom.boredorm.TenantDashboardControl.TenantDashboardController">
    <left>
        <VBox prefHeight="600.0" prefWidth="200.0" style="-fx-background-color: #111111;" BorderPane.alignment="CENTER">
            <children>
                <Label text="BoreDorm" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                    <VBox.margin>
                        <javafx.geometry.Insets bottom="40.0" left="20.0" top="20.0" />
                    </VBox.margin>
                </Label>
                <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #ffffff; -fx-text-fill: #000000; -fx-alignment: center-left; -fx-padding: 10;" text="My Profile">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <VBox VBox.vgrow="ALWAYS" />
                <Button fx:id="signOutButton" mnemonicParsing="false" onAction="#handleLogout" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #aaaaaa; -fx-alignment: center-left; -fx-padding: 20;" text="Sign Out" />
            </children>
        </VBox>
    </left>
    <center>
        <AnchorPane prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: #ffffff;" BorderPane.alignment="CENTER">
            <children>
                <Label layoutX="40.0" layoutY="40.0" text="My Tenant Portal">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>
                <AnchorPane layoutX="40.0" layoutY="120.0" prefHeight="200.0" prefWidth="520.0" style="-fx-border-color: #000000; -fx-border-width: 2; -fx-padding: 20;">
                    <children>
                        <Label layoutX="20.0" layoutY="20.0" text="Room Assignments:">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="roomLabel" layoutX="180.0" layoutY="20.0" text="Loading..." />

                        <Label layoutX="20.0" layoutY="60.0" text="Username">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="nameLabel" layoutX="180.0" layoutY="60.0" text="Loading..." />

                        <Label layoutX="20.0" layoutY="100.0" text="Lease Status:">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="statusLabel" layoutX="180.0" layoutY="100.0" text="Loading..." />
                    </children>
                </AnchorPane>
            </children>
        </AnchorPane>
    </center>
</BorderPane>
