<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boredom.boredorm.LoginControl.LoginController" prefWidth="960" prefHeight="680"
           style="-fx-background-color: #F4F4F6, radial-gradient(focus-angle 30deg, focus-distance 40%, center 15% 25%, radius 85%, rgba(255, 126, 95, 0.15) 0%, rgba(244, 244, 246, 0) 60%), radial-gradient(focus-angle 210deg, focus-distance 35%, center 80% 75%, radius 75%, rgba(254, 180, 123, 0.12) 0%, rgba(244, 244, 246, 0) 70%); -fx-padding: 40;">

    <!-- Centered Containment Card -->
    <HBox alignment="CENTER" maxWidth="840" maxHeight="520" StackPane.alignment="CENTER"
          style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-border-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.08), 24, 0, 0, 8);">

        <!-- LEFT PANEL -->
        <VBox alignment="CENTER_LEFT" spacing="12" HBox.hgrow="ALWAYS" prefWidth="420"
              style="-fx-background-color: #0A0A0A; -fx-background-radius: 12 0 0 12; -fx-padding: 60;">
            <Label text="BoreDorm." style="-fx-font-family: 'Georgia'; -fx-font-size: 40; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
            <TextFlow>
                <Text text="Your space, " style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 16; -fx-fill: #F5F5F5;"/>
                <Text text="uncomplicated." style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 16; -fx-font-weight: bold; -fx-fill: #FF7E5F;"/>
            </TextFlow>
        </VBox>

        <!-- RIGHT PANEL -->
        <VBox alignment="CENTER" HBox.hgrow="NEVER" prefWidth="420" minWidth="420" maxWidth="420"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 0 12 12 0; -fx-padding: 40 50;">
            <VBox spacing="24" fillWidth="true" maxWidth="320">

                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label text="&lt;" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 14; -fx-text-fill: #4A4A4A;"/>
                        <Label text="Portal" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-text-fill: #4A4A4A; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label text="Sign In" style="-fx-font-family: 'Georgia'; -fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0A0A0A;"/>
                </VBox>

                <!-- Fields mapped to LoginController -->
                <VBox spacing="16">
                    <VBox spacing="6" alignment="CENTER_LEFT" fillWidth="true">
                        <Label text="Username" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <TextField fx:id="usernameField" onKeyPressed="#handleKeyPress" onMouseClicked="#handleUsernameClick" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 10; -fx-text-fill: #0A0A0A; -fx-font-family: 'JetBrains Mono';"/>
                    </VBox>

                    <VBox spacing="6" alignment="CENTER_LEFT" fillWidth="true">
                        <Label text="Password" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #4A4A4A;"/>
                        <PasswordField fx:id="passwordField" onKeyPressed="#handleKeyPress" style="-fx-background-color: #FFFFFF; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 10; -fx-text-fill: #0A0A0A; -fx-font-family: 'JetBrains Mono';"/>
                    </VBox>
                </VBox>

                <!-- Action Area -->
                <VBox spacing="16" alignment="CENTER">
                    <Button fx:id="signInButton" text="Sign In" onAction="#handleLogin" maxWidth="Infinity" style="-fx-background-color: #0A0A0A; -fx-text-fill: #FFFFFF; -fx-background-radius: 0; -fx-padding: 12 24; -fx-font-family: 'Inter'; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 13;"/>

                    <Hyperlink text="Forgot password?" style="-fx-font-family: 'JetBrains Mono'; -fx-font-size: 11; -fx-text-fill: #4A4A4A; -fx-underline: false;"/>

                    <Separator style="-fx-background-color: #E5E5E5; -fx-min-height: 1; -fx-max-height: 1;"/>

                    <!-- Added fx:id link target tracking to eliminate layout file validation warnings -->
                    <Button fx:id="goToRegisterButton" text="Create an Account" onAction="#handleGoToRegister" maxWidth="Infinity" style="-fx-background-color: #FFFFFF; -fx-text-fill: #0A0A0A; -fx-background-radius: 0; -fx-border-color: #0A0A0A; -fx-border-width: 2; -fx-padding: 10 24; -fx-font-family: 'Inter'; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 13;"/>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>